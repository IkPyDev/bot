# Telegram Bot Token (@BotFather, Business Mode yoqilgan)
BOT_TOKEN=123456:ABC-DEF

# PostgreSQL ulanish satri (DSN)
# Format: postgresql://FOYDALANUVCHI:PAROL@HOST:PORT/BAZA_NOMI
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/botdb

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# (Ixtiyoriy) Adminlarning Telegram ID lari (reklama yuborish uchun). Vergul bilan ajrating
ADMIN_IDS=123456789,987654321

# (Ixtiyoriy) Xabarlar nusxasi yuboriladigan kanal ID si. Bot kanalda admin bo'lishi kerak
CHANNEL_ID=-1001234567890

# (Ixtiyoriy) KUNLIK log + DB backup yuboriladigan kanal ID si.
# Sozlanmasa CHANNEL_ID ishlatiladi. Bot bu kanalda ham admin bo'lishi kerak.
BACKUP_CHANNEL_ID=-1009876543210

# (Ixtiyoriy) Kunlik backup vaqti "HH:MM" (server mahalliy vaqti). Default 00:30
BACKUP_TIME=00:30

# (Ixtiyoriy) /start va ulanish media'si "database" kanalda turadi.
# Bot o'sha kanaldagi xabardan copy_message bilan olib, caption qo'shib yuboradi.
# Bot bu kanalning a'zosi/admini bo'lishi SHART. Bo'sh bo'lsa — faqat matn ketadi.
MEDIA_CHANNEL_ID=-1004302584743
START_MEDIA_MESSAGE_ID=3      # /start rasmi/videosi xabar ID
CONNECT_MEDIA_MESSAGE_ID=2   # ulanish qo'llanma videosi xabar ID
